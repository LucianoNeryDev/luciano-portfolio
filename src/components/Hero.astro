---
import { RotatingText } from '../react-components';
---

<header class="mobile-bar">
  <div class="brand">Luciano <span class="italic-serif">Nery</span></div>
  <div class="role">Full-Stack Dev</div>
</header>

<section id="hero">
  <div class="section-marker">
    <span class="rule short"></span>
    <span class="label">Portfolio · MMXXVI</span>
  </div>

  <h1 class="title">
    Building <span class="accent">robust,</span><br />
    scalable<br />
    web <span class="accent">experiences.</span>
  </h1>

  <div class="row-2">
    <p class="lede">
      Full-stack developer specialising in production-grade web applications —
      from the pixel detail of an interface to the database schema and the
      production server it runs on.
    </p>
    <div class="ctas">
      <a class="btn btn-solid" href="#work">View Work ↓</a>
      <a class="btn btn-outline" href="#contact">Get in touch</a>
    </div>
  </div>

  <div class="rotator">
    <span class="rotator-label">Currently building →</span>
    <RotatingText
      items={["Websites", "Databases", "AI integrations", "SaaS products", "Backend systems", "Bots", "Applications"]}
      fontSize='20px'
      client:load
    />
  </div>
</section>

<style>
  .mobile-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid var(--color-hairline);
  }
  .mobile-bar .brand {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .mobile-bar .role {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.55);
  }
  @media (min-width: 1024px) { .mobile-bar { display: none; } }

  #hero {
    padding: 64px clamp(24px, 5vw, 96px) 96px;
    border-bottom: 1px solid var(--color-hairline);
  }
  @media (min-width: 1024px) { #hero { padding-top: 96px; } }
  @media (min-width: 1280px) { #hero { padding-top: 112px; } }

  .section-marker { margin-bottom: 48px; }
  .section-marker .rule.short { width: 40px; flex: none; background: rgba(232, 228, 220, 0.4); }

  .title {
    font-family: var(--font-serif);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.02em;
    font-size: clamp(44px, 9vw, 112px);
  }
  .title .accent {
    font-style: italic;
    font-weight: 400;
    color: rgba(232, 228, 220, 0.7);
  }

  .row-2 {
    margin-top: 48px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: end;
  }
  @media (min-width: 768px) {
    .row-2 { grid-template-columns: 7fr 5fr; }
  }
  .lede {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(232, 228, 220, 0.65);
    max-width: 520px;
  }
  @media (min-width: 1280px) { .lede { font-size: 16px; } }
  .ctas { display: flex; flex-wrap: wrap; gap: 12px; }
  @media (min-width: 768px) { .ctas { justify-content: flex-end; } }

  .rotator {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid var(--color-hairline);
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .rotator-label {
    font-family: var(--font-mono);
    font-size: 15px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.45);
  }
  .rotator :global(.react-container) { display: inline-flex; }
</style>
