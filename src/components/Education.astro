<section id="education" class="section">
  <div class="section-marker">
    <span class="num">03</span>
    <span class="rule"></span>
    <span class="label">Education</span>
  </div>

  <h2 class="section-title">Foundations.</h2>

  <div class="list">
    <div class="row">
      <div class="title">Systems Analysis &amp; Development</div>
      <div class="date">2024 — 2027</div>
    </div>
    <div class="row column">
      <div class="title">Harvard CS50 — series</div>
      <div class="tags">
        <span class="tag">CS50</span>
        <span class="tag">CS50x — Python</span>
        <span class="tag">CS50W — Web</span>
        <span class="tag">CS50 AI</span>
      </div>
    </div>
  </div>
</section>

<style>
  .section-title { margin-bottom: 64px; }
  .list {
    border-top: 1px solid rgba(232, 228, 220, 0.25);
    max-width: 720px;
  }
  .row {
    padding: 28px 0;
    border-bottom: 1px solid var(--color-hairline);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
  }
  .row.column {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }
  .row .title {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--color-bone);
  }
  @media (min-width: 1280px) { .row .title { font-size: 24px; } }
  .row .date {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: rgba(232, 228, 220, 0.5);
    white-space: nowrap;
  }
</style>
