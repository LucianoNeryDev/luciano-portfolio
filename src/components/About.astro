---

<section id="about" class="section">
  <div class="section-marker">
    <span class="num">04</span>
    <span class="rule"></span>
    <span class="label">About</span>
  </div>

  <div class="grid">
    <h2 class="title">
      End-to-end<br /><span class="accent">ownership.</span>
    </h2>
    <p class="body">
      I'm a full-stack developer who enjoys shipping end-to-end — from the pixel
      detail of an interface to the database schema and the production server it
      runs on. Based in Italy. Available for remote work, worldwide.
    </p>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  @media (min-width: 768px) {
    .grid { grid-template-columns: 5fr 7fr; }
  }
  .title {
    font-family: var(--font-serif);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 0.95;
    font-size: clamp(40px, 6vw, 56px);
  }
  .title .accent {
    font-style: italic;
    font-weight: 400;
    color: rgba(232, 228, 220, 0.7);
  }
  .body {
    font-size: 15px;
    line-height: 1.8;
    color: rgba(232, 228, 220, 0.7);
    max-width: 560px;
  }
  @media (min-width: 1280px) { .body { font-size: 16px; } }
</style>
